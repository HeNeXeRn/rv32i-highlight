{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RISC-V Disassembly",
  "scopeName": "source.riscv.disasm",
  "patterns": [
    {
      "name": "comment.block.riscv.disasm",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "comment.line.double-slash.riscv.disasm",
      "match": "//.*$"
    },
    {
      "name": "comment.line.number-sign.riscv.disasm",
      "match": "#.*$"
    },
    {
      "begin": "<",
      "end": ">",
      "name": "meta.disasm.target.riscv.disasm",
      "patterns": [
        {
          "name": "entity.name.tag.label.definition.riscv.disasm",
          "match": "[a-zA-Z_][a-zA-Z0-9_.$@]*"
        }
      ]
    },
    {
      "name": "entity.name.tag.label.definition.riscv.disasm",
      "match": "^[\\t ]*[a-zA-Z_][a-zA-Z0-9_]*:"
    },
    {
      "name": "constant.language.numeric.address.riscv.disasm",
      "match": "^[\\t ]*0x[0-9a-fA-F]+\\b"
    },
    {
      "name": "keyword.control.riscv.disasm",
      "match": "\\b(add|addi|sub|lui|auipc|jal|jalr|beq|bne|blt|bge|bltu|bgeu|lb|lh|lw|lbu|lhu|sb|sh|sw|sll|slli|slt|slti|sltiu|sltu|srl|srli|sra|srai|or|ori|and|andi|ecall|ebreak|mul|div|rem|beqz|bnez|j|jr|la|li|mv|neg|nop|not|ret)\\b"
    },
    {
      "name": "invalid.illegal.register.riscv.disasm",
      "match": "\\b(x[0-9]|x[1-2][0-9]|x3[0-1]|zero|ra|sp|gp|tp|t[0-6]|s10|s11|s[0-9]|a[0-7])\\b"
    },
    {
      "name": "constant.language.numeric.riscv.disasm",
      "match": "(?<![+a-zA-Z0-9_])(?:-?\\d+|0x[0-9a-fA-F]+)\\b"
    }
  ]
}
