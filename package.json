{
  "name": "rv32i-highlight",
  "displayName": "rv32i-highlight",
  "description": "Highlighter for RV32I Assembly",
  "version": "0.2.0",
  "publisher": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/HeNeXeRn/rv32i-highlight.git"
  },
  "bugs": {
    "url": "https://github.com/HeNeXeRn/rv32i-highlight/issues"
  },
  "homepage": "https://github.com/HeNeXeRn/rv32i-highlight#readme",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:riscv",
    "onLanguage:riscv-disasm"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "riscv",
        "aliases": [
          "RISC-V",
          "riscv"
        ],
        "extensions": [
          ".s",
          ".asm"
        ]
      },
      {
        "id": "riscv-disasm",
        "aliases": [
          "RISC-V Disassembly",
          "riscv-disasm"
        ],
        "extensions": [
          ".disasm"
        ]
      }
    ],
    "grammars": [
      {
        "language": "riscv",
        "scopeName": "source.riscv",
        "path": "./syntaxes/riscv.tmLanguage.json"
      },
      {
        "language": "riscv-disasm",
        "scopeName": "source.riscv.disasm",
        "path": "./syntaxes/riscv-disasm.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "definedLabel",
        "description": "Labels"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "riscv",
        "scopes": {
          "definedLabel": [
            "entity.name.tag"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "keyword.control.riscv.disasm",
            "settings": {
              "foreground": "#0DBC79"
            }
          },
          {
            "scope": "invalid.illegal.register.riscv.disasm",
            "settings": {
              "foreground": "#D75959"
            }
          },
          {
            "scope": "entity.name.tag.label.definition.riscv.disasm",
            "settings": {
              "foreground": "#E5E510"
            }
          },
          {
            "scope": [
              "comment.block.riscv.disasm",
              "comment.line.double-slash.riscv.disasm",
              "comment.line.number-sign.riscv.disasm"
            ],
            "settings": {
              "foreground": "#636363"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.103.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
